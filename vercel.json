{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ai-resume-checker-f4xs.onrender.com/api/:path*"
    }
  ],
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/" }
  ]
}

